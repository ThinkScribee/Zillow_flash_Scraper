  text-transform: uppercase;
  line-height: 1;
}
.rdtPicker td.day:hover,
.rdtPicker td.hour:hover,
.rdtPicker td.minute:hover,
.rdtPicker td.second:hover,
.rdtPicker .timeToggle:hover {
  background: #f9f9fb;
  color: #006aff;
  border-radius: 50%;
